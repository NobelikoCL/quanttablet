# ── Entorno virtual Python (OS-especifico, se recrea con install.bat)
backend/venv/
backend/env/
backend/.venv/

# ── Dependencias Node (se reinstalan con npm install)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.eslintcache

# ── Bytecode Python (se regenera automaticamente, NO sirve entre versiones)
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Logs (pueden pesar cientos de MB con rotacion)
backend/*.log
backend/*.log.*

# ── Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs
.vscode/
.idea/
*.suo
*.user
*.sln.docstates

# ── Claude Code (configuracion local de esta maquina)
.claude/
